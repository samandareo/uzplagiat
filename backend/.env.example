# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Databases
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/uzplagiat_auth
MONGO_URL=mongodb://admin:password@mongo:27017

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ML Paths (for Docker, these point to /app inside container)
MODEL_PATH=/app/uzbek-plagiarism-model
FAISS_INDEX_PATH=/app/plagiarism_db.index
TEXTS_CSV_PATH=/app/plagiarism_db_texts.csv
